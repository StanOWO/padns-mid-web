# Vercel Postgres — 在 Vercel Dashboard > Storage 建立 Postgres 後自動填入
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# JWT Secret — 請改為一段隨機字串
JWT_SECRET=your-random-secret-key-here-change-me

# (選用) Google Gemini API Key — 用於 AI 文字改寫功能 (加分項目)
# 到 https://aistudio.google.com/apikey 免費取得
GEMINI_API_KEY=
